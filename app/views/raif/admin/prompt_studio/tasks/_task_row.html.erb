<tr>
  <% if show_checkbox %>
    <td><input type="checkbox" name="source_task_ids[]" value="<%= task.id %>" class="form-check-input task-checkbox" data-raif--select-all-checkboxes-target="checkbox" data-action="raif--select-all-checkboxes#updateCount"></td>
  <% end %>
  <td><%= task.id %></td>
  <td><%= task.type %></td>
  <td><%= task.created_at.rfc822 %></td>
  <td><%= task.llm_model_key %></td>
  <td>
    <%= link_to "View", raif.admin_prompt_studio_task_path(task), class: "btn btn-sm btn-outline-primary" %>
  </td>
</tr>
