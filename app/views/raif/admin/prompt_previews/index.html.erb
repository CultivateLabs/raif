<div class="d-flex justify-content-between align-items-center my-4">
  <h1 class="mb-0"><%= t("raif.admin.prompt_previews.index.title") %></h1>
</div>

<% if @previews.empty? %>
  <div class="alert alert-info">
    <p class="mb-0"><%= t("raif.admin.prompt_previews.index.no_previews") %></p>
    <p class="mt-2 mb-0"><%= t("raif.admin.prompt_previews.index.no_previews_hint") %></p>
  </div>
<% else %>
  <div class="row">
    <div class="col-12">
      <% @previews.each do |preview_class| %>
        <div class="card mb-3">
          <div class="card-header">
            <h5 class="mb-0"><%= preview_class.preview_name %></h5>
          </div>
          <div class="card-body">
            <ul class="list-unstyled mb-0">
              <% preview_class.preview_methods.each do |method_name| %>
                <li class="mb-1">
                  <%= link_to method_name, raif.method_admin_prompt_preview_path(id: preview_class.preview_id, method_name: method_name) %>
                </li>
              <% end %>
            </ul>
          </div>
        </div>
      <% end %>
    </div>
  </div>
<% end %>
